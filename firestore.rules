rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Admin email must match ADMIN_EMAIL in your server env (see docs/firestore-rules-core.md).
    // Hosted production (huntmode.ca) uses marcsherwood@gmail.com; self-hosters replace both places.
    function isApproved(uid) {
      return request.auth != null && (
        (request.auth.token.email == 'marcsherwood@gmail.com' && request.auth.token.email_verified == true) ||
        (exists(/databases/$(database)/documents/accessRequests/$(uid)) &&
         get(/databases/$(database)/documents/accessRequests/$(uid)).data.status == 'approved')
      );
    }

    function isAdmin() {
      return request.auth != null &&
        request.auth.token.email == 'marcsherwood@gmail.com' &&
        request.auth.token.email_verified == true;
    }

    // Other-user directory / access control — admin only.
    match /accessRequests/{uid} {
      allow read, write: if isAdmin();
    }

    // Each user may only read/write their own data tree (except server-owned usage ledger).
    match /users/{uid}/profile/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == uid && isApproved(uid);
    }
    match /users/{uid}/applications/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == uid && isApproved(uid);
    }
    match /users/{uid}/masterResumes/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == uid && isApproved(uid);
    }
    match /users/{uid}/goals/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == uid && isApproved(uid);
    }
    match /users/{uid}/activity/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == uid && isApproved(uid);
    }
    match /users/{uid}/usageEvents/{eventId} {
      allow read: if request.auth != null && request.auth.uid == uid && isApproved(uid);
      allow write: if false;
    }

    // System docs (signup rate limit, etc.) — never readable from clients.
    match /system/{document=**} {
      allow read, write: if false;
    }

    // Allow the Rock Tracker demo app to write to the global rocks collection
    match /rocks/{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
# HuntMode edition: hosted (production at huntmode.ca) | core (self-host / OSS)
HUNTMODE_EDITION=hosted
NEXT_PUBLIC_HUNTMODE_EDITION=hosted

# Admin identity — must match firestore.rules isAdmin() / isApproved() admin bypass
# Set NEXT_PUBLIC_ADMIN_EMAIL to the same value for client-side admin UI checks
ADMIN_EMAIL=you@example.com
NEXT_PUBLIC_ADMIN_EMAIL=you@example.com

# Hosted access gate: max new sign-ups per hour (ignored when HUNTMODE_EDITION=core)
SIGNUP_LIMIT_PER_HOUR=10

# Future: subsidize in-app AI for hosted users without BYOK (phase 2, off by default)
# HUNTMODE_PLATFORM_AI_FOR_USERS=false

# Firebase Web Config
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Firebase Admin (Server-side API routes)
# Generate from Firebase Console -> Project Settings -> Service Accounts
FIREBASE_ADMIN_CLIENT_EMAIL=your_firebase_admin_client_email
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# AI Provider Keys
# Users bring their own keys in Settings (BYOK). Platform keys below are optional:
# - GOOGLE_AI_API_KEY: onboarding parse/suggest on hosted; self-hosters can set for onboarding too
# - OPENAI/ANTHROPIC: fallback for hosted admin when testing without BYOK
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
GOOGLE_AI_API_KEY=your_google_ai_api_key

# Jina Search (required for Find Similar Roles and Fit tab live search)
# Get a key at https://jina.ai/
JINA_API_KEY=your_jina_api_key

# Email Access Approval (Optional — hosted)
# If set, uses Resend to send real approval emails to the admin.
# If unset, approval links are printed to the server console log for local clicking.
RESEND_API_KEY=your_resend_api_key

# PostHog analytics (optional — hosted encourages; core typically omits)
# NEXT_PUBLIC_POSTHOG_KEY=phc_your_project_token
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Tipping (“Say thanks”) — hosted only when NEXT_PUBLIC_TIP_URL is set
# NEXT_PUBLIC_TIP_URL=https://buymeacoffee.com/yourpage

---
import type { BlogCategory } from "../content.config";
import CategoryBadge from "./CategoryBadge.astro";
import { formatDate } from "../lib/blog";

interface Props {
  title: string;
  description: string;
  category: BlogCategory;
  pubDate: Date;
  updatedDate?: Date;
  author: string;
  readingTimeMinutes: number;
  tags: string[];
  guestAuthor?: boolean;
}

const {
  title,
  description,
  category,
  pubDate,
  updatedDate,
  author,
  readingTimeMinutes,
  tags,
  guestAuthor,
} = Astro.props;
---

<div class="flex flex-wrap items-center gap-3">
  <CategoryBadge category={category} />
  {guestAuthor && (
    <span class="rounded-full border border-amber-500/30 bg-amber-500/10 px-2.5 py-0.5 text-[10px] font-bold uppercase tracking-wider text-amber-200">
      Guest post
    </span>
  )}
</div>

<h1 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">{title}</h1>
<p class="text-lg text-slate-400">{description}</p>

<div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-slate-500">
  <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
  {updatedDate && (
    <time datetime={updatedDate.toISOString()}>Updated {formatDate(updatedDate)}</time>
  )}
  <span>By {author}</span>
  <span>{readingTimeMinutes} min read</span>
</div>

{tags.length > 0 && (
  <ul class="flex flex-wrap gap-2 pt-1">
    {tags.map((tag) => (
      <li>
        <span class="rounded-full border border-white/10 bg-slate-900/80 px-2.5 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-slate-400">
          {tag}
        </span>
      </li>
    ))}
  </ul>
)}

---
interface Props {
  originalUrl: string;
}

const { originalUrl } = Astro.props;
---

<div class="mb-8 rounded-xl border border-sky-500/20 bg-sky-500/10 px-4 py-3 text-sm text-sky-100">
  Originally published at{" "}
  <a href={originalUrl} target="_blank" rel="noopener noreferrer" class="font-semibold underline">
    {new URL(originalUrl).hostname}
  </a>
  . Republished with permission.
</div>
